# ── Supabase ────────────────────────────────────────────────
# Da: Supabase Dashboard → Project Settings → API
# Copia questo file in .env.local e mettici i valori VERI (.env.local è in .gitignore).
# Se NON impostate, l'app usa lo storage in-memory (dev/Docker locale).
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service-role key: SOLO lato server, NON esporla mai al client/browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── (futuro) deploy FTP / immagini / auth ───────────────────
# verranno aggiunte nelle fasi successive

# ── Admin auth ──────────────────────────────────────────────
# Se ADMIN_PASSWORD non è impostata, /admin resta aperto (solo dev locale).
ADMIN_PASSWORD=scegli-una-password
# segreto per firmare il cookie di sessione (genera con: openssl rand -hex 32)
ADMIN_SESSION_SECRET=metti-un-valore-casuale-lungo
